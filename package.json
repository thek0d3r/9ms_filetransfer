{
  "name": "9ms-file-transfer",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "tsx src/worker.ts",
    "worker:start": "node dist-worker/worker.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:scan": "node scripts/scan-smoke.mjs",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "admin:promote": "tsx scripts/promote-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.864.0",
    "@aws-sdk/s3-request-presigner": "^3.864.0",
    "@fontsource-variable/archivo": "^5.2.6",
    "@fontsource/jetbrains-mono": "^5.2.6",
    "@fontsource/unbounded": "^5.2.6",
    "archiver": "^7.0.1",
    "argon2": "^0.44.0",
    "bullmq": "^5.80.2",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.7.0",
    "next": "16.2.10",
    "pg": "^8.16.3",
    "prom-client": "^15.1.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "stripe": "^22.3.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/node": "^22.18.1",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
