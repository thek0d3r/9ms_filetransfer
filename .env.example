NODE_ENV=development
APP_URL=http://localhost:3000
DATABASE_URL=postgres://9ms:9ms@localhost:5432/9ms
VALKEY_URL=redis://localhost:6379
S3_REGION=us-east-1
S3_BUCKET=9ms-transfers
S3_ACCESS_KEY_ID=replace-with-s3-access-key
S3_SECRET_ACCESS_KEY=replace-with-s3-secret-key
S3_FORCE_PATH_STYLE=false
S3_SERVER_SIDE_ENCRYPTION=AES256
TOKEN_PEPPER=replace-with-at-least-32-random-characters
COOKIE_SECRET=replace-with-at-least-32-random-characters
SECRET_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
OPS_TOKEN=replace-with-at-least-32-random-characters
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_DISABLED=false
CLAMAV_FRESHCLAM_CHECKS=6
CLAMAV_STREAM_MAX_LENGTH=10240M
CLAMAV_MAX_SCAN_SIZE=10240M
CLAMAV_MAX_FILE_SIZE=10240M
CLAMAV_MAX_SCAN_TIME_MS=1800000
CLAMAV_MAX_RECURSION=32
CLAMAV_MAX_FILES=100000
CLAMAV_DETECT_PUA=yes
# Exact SHA-256 values are checked for every file. Separate entries with commas.
CSAM_SHA256_DENYLIST=
MAX_TRANSFER_BYTES=2147483648
MAX_FILES=100
TRANSFER_TTL_HOURS=168
UPLOAD_TTL_HOURS=24
DOWNLOAD_URL_TTL_SECONDS=900
CREATE_LIMIT_PER_HOUR=12
PASSWORD_ATTEMPT_LIMIT=10
SESSION_TTL_DAYS=30
PREMIUM_MAX_TRANSFER_BYTES=10737418240
PREMIUM_MONTHLY_BYTES=53687091200
PREMIUM_PRICE_EUR_CENTS=1999
# Enable only after the service has a lawful merchant/operator and Stripe is configured.
PREMIUM_ENABLED=false
# Create a recurring EUR price in Stripe, then add its price_ identifier here.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=
